# ===== .env.example =====
# 本番では本ファイルを `.env` にコピーし、社内サーバ上で値を埋める。
# `.env` 自体は .gitignore 対象。秘密情報はここに直接書かないこと。
#
# 読込: Django 起動側で環境変数として渡す(プロセスマネージャ/起動スクリプト)。
# settings.py は os.environ.get() で参照しているため、シェル/サービスから
# export しておけば自動的に拾われる。

# ----- CS課題 翻訳ブリッジ (cs_tasks/bridge) -----

# HMAC 秘密鍵(復路の改ざん防止)。Mac 側と完全に同じ値を共有する。
# 生成例: python3 -c "import secrets; print(secrets.token_hex(32))"
CS_BRIDGE_HMAC_SECRET=

# 復路を受け付ける差出人(Mac 側 Gmail)。カンマ区切りで複数可。
CS_BRIDGE_ALLOWED_SENDERS=tosh.m909@gmail.com

# 往路スナップショットの宛先(Mac 側 Gmail)。カンマ区切りで複数可。
CS_BRIDGE_SYNC_RECIPIENTS=tosh.m909@gmail.com

# 復路で社内側に作成する Task の owner / コメント author に充てるユーザーの email。
CS_BRIDGE_AUTHOR_EMAIL=

# 送信に使う mailcenter.MailAccount のコード(未指定なら 'cs_report' を試し、
# 無ければ共通アカウントへフォールバック)。
CS_BRIDGE_MAIL_ACCOUNT=cs_report

# 復路受信箱(IMAP)。社内 cs_info@ngls.sh.cn の受信箱を使う想定。
CS_BRIDGE_INTAKE_IMAP_HOST=imap.qiye.aliyun.com
CS_BRIDGE_INTAKE_IMAP_PORT=993
CS_BRIDGE_INTAKE_IMAP_USER=cs_info@ngls.sh.cn
CS_BRIDGE_INTAKE_IMAP_PASSWORD=
CS_BRIDGE_INTAKE_IMAP_SSL=1
CS_BRIDGE_INTAKE_MAILBOX=INBOX

# ----- 既存 SMTP 設定(現状は settings.py に直書き。将来の環境変数化用) -----
# EMAIL_HOST=smtp.qiye.aliyun.com
# EMAIL_HOST_USER=cs_info@ngls.sh.cn
# EMAIL_HOST_PASSWORD=

# ----- 本船動向管理 (vessel_tracking) -----
# Datalastic AIS API キー(本船追跡)。本番はこれを設定するだけでライブ監視が
# 既定3時間ごとに自動実行される(scheduler が track_vessels を回す)。
DATALASTIC_API_KEY=
# ライブ監視の自動実行間隔(秒)。空＝既定3時間(キーがあれば自動ON)。
# 値を入れると間隔変更。「0」を明示すると無効化(開発機の誤課金防止に推奨)。
# 例: 7200(=2時間ごと)。本番は空 or 任意の秒数。
VESSEL_TRACK_INTERVAL_SEC=
